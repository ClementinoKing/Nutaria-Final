VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_FEATURE_INVENTORY_ADJUSTMENTS=true
VITE_FEATURE_CYCLE_COUNTS=true
VITE_FEATURE_CARRIERS=true
VITE_FEATURE_PROCESSING_PRODUCT_WIZARD=true

# Client-safe storage configuration
VITE_STORAGE_PROVIDER=cloudflare-r2
VITE_CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
VITE_CLOUDFLARE_R2_PUBLIC_BASE_URL=
VITE_CLOUDFLARE_R2_BUCKET=

# Server-only Cloudflare credentials. Do not expose these as VITE_* variables.
CLOUDFLARE_API_TOKEN=replace-with-server-token
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-with-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-with-secret-access-key
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=replace-with-bucket-name
CLOUDFLARE_R2_REGION=auto
